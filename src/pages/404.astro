---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout title="Fant ikke siden" description="Siden du leter etter finnes ikke.">
  <main class="not-found">
    <p class="not-found-code">404</p>
    <h1>Vi fant ikke denne siden</h1>
    <p>Adressen kan være feil, eller siden kan ha blitt flyttet.</p>
    <a href="/" class="not-found-link">Gå til forsiden</a>
  </main>
</BaseLayout>

<style>
  .not-found {
    min-height: 60vh;
    display: grid;
    place-content: center;
    justify-items: center;
    gap: var(--spacing-sm);
    padding: var(--spacing-2xl) var(--spacing-md);
    text-align: center;
  }

  .not-found-code {
    margin: 0;
    color: var(--gold-text);
    font-size: 1rem;
    font-weight: 800;
    letter-spacing: 0.16em;
  }

  .not-found h1,
  .not-found p {
    margin: 0;
  }

  .not-found h1 {
    color: var(--burgundy);
    font-size: clamp(2rem, 6vw, 3.5rem);
  }

  .not-found p {
    color: var(--text-soft);
  }

  .not-found-link {
    margin-top: var(--spacing-sm);
    padding: var(--spacing-sm) var(--spacing-md);
    border-radius: 50px;
    background-color: var(--burgundy);
    color: var(--button-text);
    font-weight: 700;
    text-decoration: none;
  }
</style>
