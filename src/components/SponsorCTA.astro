---
import './SponsorCTA.css'
---

<section class="sponsor-cta">
  <div class="sponsor-container">
    <div class="decorative-blob blob-1"></div>
    <div class="decorative-blob blob-2"></div>
    <div class="decorative-blob blob-3"></div>

    <div class="sponsor-content">
      <div class="sponsor-badge">❤️ Støtt kulturlivet</div>
      <h2 class="sponsor-heading">Bli en del av laget vårt</h2>
      <p class="sponsor-description">
        Som sponsor bidrar du til å holde brassmusikken levende i Bergen. Vi setter stor pris på
        støtte fra lokale bedrifter og enkeltpersoner som tror på kraften i musikk og fellesskap.
      </p>
      <div class="sponsor-buttons">
        <a href="/stott-oss/" class="button-gold">Bli sponsor</a>
        <a href="/om-oss/" class="button-outline">Les mer</a>
      </div>
    </div>
  </div>
</section>
