const currentYear = new Date().getFullYear()
---

<footer class="footer">
  <div class="footer-container">
    <div class="footer-grid">
      <div class="footer-brand">
        <div class="footer-logo">
          <img
            src="/images/logo-40.png"
            srcset="/images/logo-80.png 2x"
            alt=""
            width="40"
            height="40"
            class="footer-logo-image"
            loading="lazy"
          />
          <div class="footer-logo-text">Tertnes Brass</div>
        </div>
        <p class="footer-description">Et varmt og inkluderende brassband i Bergen.</p>
      </div>

      <div class="footer-column">
        <h2 class="footer-heading">Utforsk</h2>
        <ul class="footer-links">
          <li><a href="/">Hjem</a></li>
          <li><a href="/program/">Program</a></li>
          <li><a href="/nyheter/">Nyheter</a></li>
          <li><a href="/om-oss/">Om oss</a></li>
        </ul>
      </div>

      <div class="footer-column">
        <h2 class="footer-heading">Bli med</h2>
        <ul class="footer-links">
          <li><a href="/bli-medlem/">Bli medlem</a></li>
          <li><a href="/styret/">Styret</a></li>
          <li><a href="/medlemmer/">Medlemmer</a></li>
          <li><a href="/stott-oss/">Støtt oss</a></li>
        </ul>
      </div>

      <div class="footer-column">
        <h2 class="footer-heading">Kontakt</h2>
        <ul class="footer-links">
          <li><a href="mailto:tb@tertnesbrass.no">tb@tertnesbrass.no</a></li>
          <li>Tertnes skole</li>
          <li>5113 Tertnes</li>
          <li>Bergen</li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p class="footer-copyright">© {currentYear} Tertnes Brass. Laget med ❤️ i Bergen.</p>
      <div class="footer-social">
        {
          socialLinks.map((social) => (
            <a
              href={social.href}
              class="social-icon"
              aria-label={social.label}
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d={social.path} />
              </svg>
            </a>
          ))
        }
      </div>
    </div>
  </div>
</footer>
